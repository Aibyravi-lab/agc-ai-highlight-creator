# AGC Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a secure key:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-secure-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=AGC Backend
APP_VERSION=0.5.0-beta

# ─── URLs ────────────────────────────────────────────────────────────────────
# Development defaults — update for production
FRONTEND_URL=http://localhost:3000

# Production only — set these when ENVIRONMENT=production
ENVIRONMENT=development
HTTPS_ENABLED=false
PRODUCTION_URL=https://yourdomain.com
WWW_PRODUCTION_URL=https://www.yourdomain.com

# ─── Storage paths (defaults work for local dev) ─────────────────────────────
# UPLOAD_FOLDER=storage/uploads
# FRAME_FOLDER=storage/frames
# HIGHLIGHT_FOLDER=storage/highlights
# THUMBNAIL_FOLDER=storage/thumbnails
# OUTPUT_FOLDER=outputs
# RESULTS_FOLDER=outputs/results
# DATABASE_FOLDER=data
# DATABASE_NAME=agc.db
# PROGRESS_FILE=storage/progress.json

# ─── Limits ──────────────────────────────────────────────────────────────────
# MAX_UPLOAD_SIZE_MB=500
# MAX_CONCURRENT_JOBS_PER_USER=2
# TEMP_CLEANUP_HOURS=24
# DUPLICATE_UPLOAD_WINDOW_MINUTES=10

# ─── AI Scoring Pipeline ─────────────────────────────────────────────────────
# These control the two-pass scoring pipeline and synergy bonus.
# Defaults are tuned for beta; only change if you understand the impact.
# ADAPTIVE_THRESHOLD_ENABLED=true
# ADAPTIVE_THRESHOLD_PERCENTILE=60
# MIN_ADAPTIVE_THRESHOLD=0.15
# DEFAULT_HIGHLIGHT_THRESHOLD=0.20
# FINE_SCAN_WINDOW_SECONDS=5
# COARSE_TRIGGER_MULTIPLIER=0.50
# SYNERGY_ENABLED=true
# SYNERGY_SIGNAL_THRESHOLD=0.50
# SYNERGY_INCREMENT=0.10
# MAX_SYNERGY_MULTIPLIER=1.50
