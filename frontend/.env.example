# Vedzovi Frontend Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Public site URL (used for SEO metadata, Open Graph, robots.txt, sitemap.xml)
# Defaults to https://vedzovi.com if unset.
NEXT_PUBLIC_SITE_URL=https://vedzovi.com

# Backend API URL
# Development
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production — change to your deployed API domain
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# PostHog Analytics (optional)
# Analytics are disabled if either variable is missing or empty.
# Get your key at https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
